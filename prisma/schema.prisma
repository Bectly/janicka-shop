generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Float
  compareAt   Float?
  sku         String      @unique
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  brand       String?
  condition   String      @default("excellent") // new_with_tags | excellent | good | visible_wear
  sizes        String      @default("[]")
  colors       String      @default("[]")
  images       String      @default("[]")
  measurements String      @default("{}") // JSON: {chest?, waist?, hips?, length?} in cm
  fitNote      String?                    // Human-readable fit note, max 120 chars
  videoUrl     String?                    // Product video URL (15-30s, portrait 9:16)
  stock       Int         @default(1) // second-hand: each piece is unique
  featured    Boolean     @default(false)
  active      Boolean     @default(true)
  sold        Boolean     @default(false) // marks item as sold (unavailable)
  reservedUntil DateTime? // reservation expiry — null means not reserved
  reservedBy    String?   // visitor ID who reserved this item
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems    OrderItem[]
  priceHistory  PriceHistory[]

  @@index([categoryId])
  @@index([featured])
  @@index([active])
  @@index([sold])
  @@index([reservedUntil])
  @@index([reservedBy])
  @@index([brand])
  @@index([createdAt])
  @@index([price])
  @@index([active, sold, createdAt]) // Most common listing query
  @@index([active, sold, featured])  // Featured products query
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  firstName String
  lastName  String
  phone     String?
  street    String?
  city      String?
  zip       String?
  country   String   @default("CZ")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  accessToken   String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  status        String      @default("pending")
  paymentMethod String?
  paymentId     String?
  subtotal      Float
  shipping      Float       @default(0)
  total         Float
  note          String?
  shippingName  String?
  shippingStreet String?
  shippingCity  String?
  shippingZip   String?
  shippingCountry String    @default("CZ")
  shippingMethod String?
  shippingPointId String?
  trackingNumber String?
  shippedAt                DateTime?   // Set when admin changes status to "shipped"
  reviewEmailSentAt        DateTime?   // Set when review request email is sent (prevents duplicates)
  deliveryCheckEmailSentAt DateTime?   // Set when delivery check-in email is sent (ship+4d)
  crossSellEmailSentAt     DateTime?   // Set when T+14 cross-sell follow-up email is sent
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  invoices      Invoice[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  size      String?
  color     String?

  @@index([orderId])
  @@index([productId])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number      String   @unique
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  totalAmount Float
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model NewsletterSubscriber {
  id                     String    @id @default(cuid())
  email                  String    @unique
  active                 Boolean   @default(true)
  firstName              String?
  preferredSizes         String    @default("[]") // JSON array of size strings e.g. ["S","M","38"]
  preferredCategories    String    @default("[]") // JSON array of category IDs
  preferredBrands        String    @default("[]") // JSON array of brand name strings
  source                 String    @default("website") // website, checkout, import
  preferenceFilter       String?                        // Filter type: "new_arrivals" | "discounts" | null (all)
  pausedUntil            DateTime?                      // If set and > now(), skip this subscriber in crons
  lastNewArrivalEmailAt  DateTime?                      // Last time a new-arrival email was sent (prevents spam)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt @default(now())
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price     Float
  changedAt DateTime @default(now())

  @@index([productId])
  @@index([changedAt])
}

model ProductNotifyRequest {
  id         String   @id @default(cuid())
  email      String
  categoryId String
  sizes      String   @default("[]") // JSON array of preferred sizes
  brand      String?                  // optional brand preference
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([categoryId])
  @@index([email])
  @@index([notified])
}

model AbandonedCart {
  id               String    @id @default(cuid())
  email            String
  customerName     String?
  cartItems        String    @default("[]") // JSON: [{productId, name, price, size, color, image, slug}]
  cartTotal        Float     @default(0)
  pageUrl          String?                  // page where cart was abandoned (checkout, cart, etc.)
  visitorId        String?                  // visitor ID for dedup
  marketingConsent Boolean   @default(false) // GDPR: opt-in for recovery emails (Czech law requires explicit consent for marketing)
  email1SentAt     DateTime?                // 30-60 min reminder
  email2SentAt     DateTime?                // 12-24h follow-up
  email3SentAt     DateTime?                // 48-72h final
  recoveredOrderId String?                  // set when customer completes order
  status           String    @default("pending") // pending | recovered | expired
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model BrowseAbandonment {
  id           String    @id @default(cuid())
  email        String
  productId    String
  productSlug  String
  productName  String
  productImage String?   // First image URL for email
  productPrice Float
  productBrand String?
  productSize  String?   // Primary size string for email copy
  sentAt       DateTime? // Set when email is sent (null = pending)
  status       String    @default("pending") // pending | sent | sold | cart_added
  createdAt    DateTime  @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([productId])
}

model Collection {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  slug        String    @unique
  image       String?                   // featured image URL
  productIds  String    @default("[]")  // JSON array of product IDs
  featured    Boolean   @default(false) // show on homepage
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  startDate   DateTime?                 // optional: collection visibility start
  endDate     DateTime?                 // optional: collection visibility end
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([featured])
  @@index([active])
}

model ShopSettings {
  id            String  @id @default("singleton")
  shopName      String  @default("Janička")
  description   String  @default("")
  contactEmail  String  @default("")
  contactPhone  String  @default("")
  street        String  @default("")
  city          String  @default("")
  zip           String  @default("")
  ico           String  @default("")
  dic           String  @default("")
  instagram     String  @default("")
  facebook      String  @default("")
  updatedAt     DateTime @updatedAt
}
