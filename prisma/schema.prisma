generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Float
  compareAt   Float?
  sku         String      @unique
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  brand       String?
  condition   String      @default("excellent") // new_with_tags | excellent | good | visible_wear
  sizes       String      @default("[]")
  colors      String      @default("[]")
  images      String      @default("[]")
  stock       Int         @default(1) // second-hand: each piece is unique
  featured    Boolean     @default(false)
  active      Boolean     @default(true)
  sold        Boolean     @default(false) // marks item as sold (unavailable)
  reservedUntil DateTime? // reservation expiry — null means not reserved
  reservedBy    String?   // visitor ID who reserved this item
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems    OrderItem[]
  priceHistory  PriceHistory[]

  @@index([categoryId])
  @@index([featured])
  @@index([active])
  @@index([sold])
  @@index([reservedUntil])
  @@index([reservedBy])
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  phone     String?
  street    String?
  city      String?
  zip       String?
  country   String   @default("CZ")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  accessToken   String?
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  status        String      @default("pending")
  paymentMethod String?
  paymentId     String?
  subtotal      Float
  shipping      Float       @default(0)
  total         Float
  note          String?
  shippingName  String?
  shippingStreet String?
  shippingCity  String?
  shippingZip   String?
  shippingCountry String    @default("CZ")
  shippingMethod String?
  shippingPointId String?
  trackingNumber String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  invoices      Invoice[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  size      String?
  color     String?

  @@index([orderId])
  @@index([productId])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number      String   @unique
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  totalAmount Float
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price     Float
  changedAt DateTime @default(now())

  @@index([productId])
  @@index([changedAt])
}

model ShopSettings {
  id            String  @id @default("singleton")
  shopName      String  @default("Janička")
  description   String  @default("")
  contactEmail  String  @default("")
  contactPhone  String  @default("")
  street        String  @default("")
  city          String  @default("")
  zip           String  @default("")
  ico           String  @default("")
  dic           String  @default("")
  instagram     String  @default("")
  facebook      String  @default("")
  updatedAt     DateTime @updatedAt
}
